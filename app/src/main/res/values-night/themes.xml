<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StatusVault" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.StatusVault.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/Theme.StatusVault</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
